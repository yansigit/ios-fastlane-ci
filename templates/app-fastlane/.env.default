# App-specific config read by the shared fastlane lanes (ios-fastlane-ci). No secrets.
FL_SCHEME=<SCHEME>
FL_BUNDLE_ID=<BUNDLE_ID>
FL_PROJECT=<APP>.xcodeproj
# FL_WORKSPACE=<APP>.xcworkspace   # use instead of FL_PROJECT for CocoaPods apps
# FL_OUTPUT_DIR=build
# FL_CONFIGURATION=Release
FASTLANE_SKIP_UPDATE_CHECK=1
